# Kaero Mobile — Environment Variables
# Copy to .env for local development
# For EAS cloud builds, values are set in eas.json or EAS secrets dashboard

# Backend API URL
# Local dev: http://192.168.X.X:3000/api/v1 (use your machine's LAN IP, not localhost)
# Production: https://kaerofinal2-production.up.railway.app/api/v1
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
